library(aLBI)
library(dplyr)
library(openxlsx)
library(readxl)
fdata <- read_excel("modelFreq.xlsx", sheet = 1)
FishPar(data = fdata, resample = 1000, progress = T, Lmat = 45)
FishPar(data = fdata, resample = 1000, progress = T, Lmat = 45, Lmat_sd = 1.2)
FishPar(data = fdata, resample = 1000, progress = T, Lmat = 48, Lmat_sd = 1.2)
# Data preparation
lengths <- c(12, 15, 18, 21, 24, 27, 30, 33, 36, 39, 42, 45, 48, 51, 54, 57, 60, 63, 66, 69, 78)
freq <- c(15, 63, 135, 137, 135, 156, 143, 80, 88, 67, 39, 36, 28, 17, 13, 5, 7, 7, 3, 2, 1)
total_freq <- sum(freq)  # 1177
# Assume maturity starts at 45 cm and increases to 100% at higher lengths
# Create proportion mature (simplified initial guess)
cum_freq <- rev(cumsum(rev(freq)))  # Cumulative frequency from largest to smallest
prop_mature <- c(rep(0, 11), cum_freq[11:21] / total_freq)  # 0 for <45 cm, proportion for ≥45 cm
# Data frame
data <- data.frame(Length = lengths, Prop_Mature = prop_mature)
# Fit logistic curve
logistic_model <- nls(Prop_Mature ~ 1 / (1 + exp(-k * (Length - L50))),
data = data,
start = list(L50 = 45, k = 0.1),
control = nls.control(maxiter = 1000))
# Summary of the fit
summary(logistic_model)
# Predict maturity probabilities
data$Predicted_Mature <- predict(logistic_model, newdata = data)
# Plot the ogive
plot(data$Length, data$Prop_Mature, pch = 16, xlab = "Length (cm)", ylab = "Proportion Mature",
main = "Maturity Ogive", ylim = c(0, 1))
lines(data$Length, data$Predicted_Mature, col = "red", lwd = 2)
abline(v = 43.73, col = "blue", lty = 2)  # FishPar Lmat
abline(v = 45, col = "green", lty = 2)    # Manual threshold
legend("topleft", legend = c("Observed", "Logistic Fit", "FishPar Lmat (43.73 cm)", "Manual Threshold (45 cm)"),
col = c("black", "red", "blue", "green"), pch = c(16, NA, NA, NA), lty = c(NA, 1, 2, 2))
# Predict maturity probabilities
data$Predicted_Mature <- predict(logistic_model, newdata = data)
# Fit logistic curve
logistic_model <- nls(Prop_Mature ~ 1 / (1 + exp(-k * (Length - L50))),
data = data,
start = list(L50 = 45, k = 0.1),
control = nls.control(maxiter = 1000))
data
# Data frame
data <- data.frame(Length = lengths, Prop_Mature = prop_mature)
# Assume maturity starts at 45 cm and increases to 100% at higher lengths
# Create proportion mature (simplified initial guess)
cum_freq <- rev(cumsum(rev(freq)))  # Cumulative frequency from largest to smallest
prop_mature <- c(rep(0, 11), cum_freq[11:21] / total_freq)  # 0 for <45 cm, proportion for ≥45 cm
# Data frame
data <- data.frame(Length = lengths, Prop_Mature = prop_mature)
# Data preparation
lengths <- c(12, 15, 18, 21, 24, 27, 30, 33, 36, 39, 42, 45, 48, 51, 54, 57, 60, 63, 66, 69, 78)
freq <- c(15, 63, 135, 137, 135, 156, 143, 80, 88, 67, 39, 36, 28, 17, 13, 5, 7, 7, 3, 2, 1)
total_freq <- sum(freq)  # 1177
# Calculate cumulative frequency from largest to smallest
cum_freq <- rev(cumsum(rev(freq)))
# Assign proportion mature: 0 for lengths < 45 cm, proportion based on cumulative freq for ≥ 45 cm
# Index 12 corresponds to 45 cm (the first mature class)
prop_mature <- numeric(length(lengths))
prop_mature[lengths < 45] <- 0  # All lengths below 45 cm are immature
prop_mature[lengths >= 45] <- cum_freq[lengths >= 45] / total_freq
# Data frame
data <- data.frame(Length = lengths, Prop_Mature = prop_mature)
# Fit logistic curve
logistic_model <- nls(Prop_Mature ~ 1 / (1 + exp(-k * (Length - L50))),
data = data,
start = list(L50 = 45, k = 0.1),
control = nls.control(maxiter = 1000))
# Summary of the fit
summary(logistic_model)
# Predict maturity probabilities
data$Predicted_Mature <- predict(logistic_model, newdata = data)
# Plot the ogive
plot(data$Length, data$Prop_Mature, pch = 16, xlab = "Length (cm)", ylab = "Proportion Mature",
main = "Maturity Ogive", ylim = c(0, 1))
lines(data$Length, data$Predicted_Mature, col = "red", lwd = 2)
abline(v = 43.73, col = "blue", lty = 2)  # FishPar Lmat
