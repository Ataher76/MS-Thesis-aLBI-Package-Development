senlen$Code <- as.factor(senlen$Code)
senlen %>%
select(2:5) %>%
pivot_longer(cols = 3:5, names_to = "range", values_to = "value") %>%
ggplot(aes(Code, value, fill = Par))+
geom_boxplot(show.legend = F)+
facet_wrap(~Par, scales = "free_y")+
scale_color_npg()+
theme_bw()
