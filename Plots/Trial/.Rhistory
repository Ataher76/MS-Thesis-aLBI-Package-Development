emmean <- emmeans::emmeans(aov, specs = "data[[1]]")
emmean_cld <- multcomp::cld(emmean, Letters = letters)
plot <- ggplot2::ggplot(data = data, aes(x = as.factor(data[[1]]), y = data[[2]], fill = as.factor(data[[1]]))) +
